# platform/dashboard.lex — self-contained HTML dashboard for the platform.
#
# Served at GET / by platform/server.lex.
# Polls /v1/health every 5 s and /v1/audit every 10 s.
# No external dependencies — everything inline.

fn page() -> Str {
  "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>lex-soft platform</title>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;\n         background: #0f1117; color: #e2e8f0; font-size: 13px; line-height: 1.6; }\n  header { display: flex; align-items: center; gap: 12px; padding: 16px 24px;\n           border-bottom: 1px solid #1e2433; }\n  header h1 { font-size: 15px; font-weight: 600; color: #93c5fd; letter-spacing: .04em; }\n  .dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e;\n         box-shadow: 0 0 6px #22c55e; animation: pulse 2s infinite; }\n  @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:.4 } }\n  #ts { margin-left: auto; color: #64748b; font-size: 11px; }\n  main { display: grid; grid-template-columns: 300px 1fr; gap: 0;\n         height: calc(100vh - 53px); }\n  aside { border-right: 1px solid #1e2433; padding: 20px; overflow-y: auto; }\n  .section-title { font-size: 10px; font-weight: 700; letter-spacing: .12em;\n                   color: #475569; text-transform: uppercase; margin-bottom: 12px; }\n  .card { background: #161b27; border: 1px solid #1e2433; border-radius: 6px;\n          padding: 14px; margin-bottom: 10px; }\n  .metric { display: flex; justify-content: space-between; align-items: center;\n            padding: 4px 0; border-bottom: 1px solid #1e2433; }\n  .metric:last-child { border-bottom: none; }\n  .metric .label { color: #94a3b8; }\n  .metric .value { font-weight: 600; color: #f1f5f9; }\n  .badge { display: inline-block; padding: 1px 7px; border-radius: 3px;\n           font-size: 11px; font-weight: 600; }\n  .badge-green  { background: #14532d; color: #86efac; }\n  .badge-yellow { background: #713f12; color: #fde68a; }\n  .badge-blue   { background: #1e3a5f; color: #93c5fd; }\n  .badge-gray   { background: #1e293b; color: #94a3b8; }\n  .kind-pill { background: #1e293b; color: #7dd3fc; padding: 2px 8px;\n               border-radius: 4px; font-size: 11px; margin-right: 4px; }\n  section.log-pane { padding: 20px; overflow: hidden; display: flex;\n                     flex-direction: column; }\n  .log-controls { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }\n  .log-controls input, .log-controls select {\n    background: #161b27; border: 1px solid #2d3748; color: #e2e8f0;\n    border-radius: 4px; padding: 5px 10px; font-family: inherit; font-size: 12px;\n    outline: none; }\n  .log-controls input:focus, .log-controls select:focus { border-color: #3b82f6; }\n  #log-table-wrap { flex: 1; overflow-y: auto; }\n  table { width: 100%; border-collapse: collapse; }\n  th { position: sticky; top: 0; background: #0f1117; color: #475569;\n       font-size: 10px; letter-spacing: .08em; text-transform: uppercase;\n       padding: 6px 10px; text-align: left; border-bottom: 1px solid #1e2433; }\n  td { padding: 6px 10px; border-bottom: 1px solid #131925; vertical-align: top; }\n  tr:hover td { background: #161b27; }\n  .event-kind { font-weight: 600; }\n  .ek-received      { color: #7dd3fc; }\n  .ek-llm_start     { color: #a78bfa; }\n  .ek-llm_done      { color: #86efac; }\n  .ek-sent          { color: #6ee7b7; }\n  .ek-error         { color: #f87171; }\n  .ek-agent_registered { color: #fbbf24; }\n  .ek-heartbeat     { color: #94a3b8; }\n  .ek-msg_delivered { color: #f9a8d4; }\n  .ek-msg_pulled    { color: #c4b5fd; }\n  .ek-state_saved   { color: #67e8f9; }\n  .data-cell { max-width: 280px; overflow: hidden; text-overflow: ellipsis;\n               white-space: nowrap; color: #64748b; cursor: pointer; }\n  .data-cell:hover { white-space: normal; word-break: break-all; color: #94a3b8; }\n  .ts-cell { white-space: nowrap; color: #475569; font-size: 11px; }\n  .empty { color: #475569; text-align: center; padding: 40px; }\n  #err-banner { display: none; background: #7f1d1d; color: #fca5a5;\n                padding: 8px 24px; font-size: 12px; }\n</style>\n</head>\n<body>\n<div id=\"err-banner\"></div>\n<header>\n  <div class=\"dot\" id=\"status-dot\"></div>\n  <h1>lex-soft platform</h1>\n  <span id=\"ts\">—</span>\n</header>\n<main>\n  <aside>\n    <div class=\"section-title\">Health</div>\n    <div class=\"card\" id=\"agent-card\">\n      <div class=\"metric\"><span class=\"label\">total agents</span><span class=\"value\" id=\"total-agents\">—</span></div>\n      <div id=\"by-kind\"></div>\n    </div>\n    <div class=\"section-title\" style=\"margin-top:20px\">Queues</div>\n    <div class=\"card\">\n      <div class=\"metric\"><span class=\"label\">push pending</span><span class=\"value\" id=\"push-pending\">—</span></div>\n      <div class=\"metric\"><span class=\"label\">pull pending</span><span class=\"value\" id=\"pull-pending\">—</span></div>\n    </div>\n  </aside>\n  <section class=\"log-pane\">\n    <div class=\"section-title\">Audit log</div>\n    <div class=\"log-controls\">\n      <input id=\"f-agent\" placeholder=\"agent_id filter\" style=\"width:160px\">\n      <select id=\"f-kind\">\n        <option value=\"\">all events</option>\n        <option>received</option>\n        <option>llm_start</option>\n        <option>llm_done</option>\n        <option>sent</option>\n        <option>error</option>\n        <option>agent_registered</option>\n        <option>heartbeat</option>\n        <option>msg_delivered</option>\n        <option>msg_pulled</option>\n        <option>state_saved</option>\n      </select>\n      <input id=\"f-since\" placeholder=\"since (ISO ts)\" style=\"width:180px\">\n      <input id=\"f-limit\" value=\"50\" style=\"width:60px\" type=\"number\" min=\"1\" max=\"500\">\n      <button onclick=\"fetchAudit()\" style=\"background:#1e3a5f;color:#93c5fd;border:1px solid #2d4a7f;border-radius:4px;padding:5px 12px;font-family:inherit;font-size:12px;cursor:pointer\">refresh</button>\n    </div>\n    <div id=\"log-table-wrap\">\n      <table>\n        <thead>\n          <tr>\n            <th>time</th>\n            <th>agent</th>\n            <th>event</th>\n            <th>data</th>\n            <th>run_id</th>\n          </tr>\n        </thead>\n        <tbody id=\"log-body\"><tr><td colspan=\"5\" class=\"empty\">loading…</td></tr></tbody>\n      </table>\n    </div>\n  </section>\n</main>\n<script>\nfunction showErr(msg) {\n  const b = document.getElementById('err-banner');\n  b.textContent = msg; b.style.display = 'block';\n  setTimeout(() => { b.style.display = 'none'; }, 4000);\n}\n\nfunction ekClass(k) {\n  return 'event-kind ek-' + k.replace(/_/g, '_');\n}\n\nfunction badge(n, warn) {\n  if (n === 0) return '<span class=\"badge badge-gray\">0</span>';\n  if (warn && n > 0) return '<span class=\"badge badge-yellow\">' + n + '</span>';\n  return '<span class=\"badge badge-blue\">' + n + '</span>';\n}\n\nfunction fetchHealth() {\n  fetch('/v1/health')\n    .then(r => r.json())\n    .then(d => {\n      if (d.error) { showErr('health: ' + d.error); return; }\n      document.getElementById('total-agents').textContent = d.agents.total;\n      const bk = document.getElementById('by-kind');\n      bk.innerHTML = (d.agents.by_kind || []).map(e =>\n        '<div class=\"metric\"><span class=\"kind-pill\">' + e.kind + '</span>'\n        + '<span class=\"value\">' + e.count + '</span></div>'\n      ).join('');\n      document.getElementById('push-pending').innerHTML = badge(d.queues.push_pending, true);\n      document.getElementById('pull-pending').innerHTML = badge(d.queues.pull_pending, true);\n      document.getElementById('ts').textContent = 'updated ' + new Date().toLocaleTimeString();\n      document.getElementById('status-dot').style.background = '#22c55e';\n    })\n    .catch(e => {\n      document.getElementById('status-dot').style.background = '#ef4444';\n      showErr('health fetch failed: ' + e.message);\n    });\n}\n\nfunction fetchAudit() {\n  const params = new URLSearchParams();\n  const agent = document.getElementById('f-agent').value.trim();\n  const kind  = document.getElementById('f-kind').value;\n  const since = document.getElementById('f-since').value.trim();\n  const limit = document.getElementById('f-limit').value;\n  if (agent) params.set('agent_id', agent);\n  if (kind)  params.set('event_kind', kind);\n  if (since) params.set('since', since);\n  if (limit) params.set('limit', limit);\n  fetch('/v1/audit?' + params.toString())\n    .then(r => r.json())\n    .then(rows => {\n      if (!Array.isArray(rows)) { showErr('audit: ' + JSON.stringify(rows)); return; }\n      const tbody = document.getElementById('log-body');\n      if (rows.length === 0) {\n        tbody.innerHTML = '<tr><td colspan=\"5\" class=\"empty\">no events</td></tr>';\n        return;\n      }\n      tbody.innerHTML = rows.map(r => {\n        const ts = r.ts ? r.ts.replace('T', ' ').replace('Z', '') : '';\n        const run = r.run_id ? r.run_id.slice(0, 12) + '…' : '';\n        return '<tr>'\n          + '<td class=\"ts-cell\">' + ts + '</td>'\n          + '<td>' + (r.agent_id || '') + '</td>'\n          + '<td><span class=\"' + ekClass(r.event_kind) + '\">' + r.event_kind + '</span></td>'\n          + '<td class=\"data-cell\" title=\"' + (r.data || '').replace(/\"/g, '&quot;') + '\">' + (r.data || '') + '</td>'\n          + '<td class=\"ts-cell\">' + run + '</td>'\n          + '</tr>';\n      }).join('');\n    })\n    .catch(e => showErr('audit fetch failed: ' + e.message));\n}\n\nfetchHealth();\nfetchAudit();\nsetInterval(fetchHealth, 5000);\nsetInterval(fetchAudit, 10000);\n</script>\n</body>\n</html>"
}

