fn page() -> Str {
  "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>lex-soft platform</title>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\"/>\n<style>\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;\n       background: #0f1117; color: #e2e8f0; font-size: 13px; line-height: 1.6; }\nheader { display: flex; align-items: center; gap: 12px; padding: 12px 24px;\n         border-bottom: 1px solid #1e2433; }\nheader h1 { font-size: 15px; font-weight: 600; color: #93c5fd; letter-spacing: .04em; }\n.dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e;\n       box-shadow: 0 0 6px #22c55e; animation: pulse 2s infinite; }\n@keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:.4 } }\n#ts { margin-left: auto; color: #64748b; font-size: 11px; }\n.tabs { display: flex; border-bottom: 1px solid #1e2433; padding: 0 24px; background: #0f1117; }\n.tab-btn { background: none; border: none; color: #64748b; font-family: inherit; font-size: 12px;\n           padding: 8px 18px; cursor: pointer; border-bottom: 2px solid transparent;\n           margin-bottom: -1px; transition: color .15s; }\n.tab-btn.active { color: #93c5fd; border-bottom-color: #3b82f6; }\n.tab-btn:hover:not(.active) { color: #e2e8f0; }\n.tab-pane { display: none; height: calc(100vh - 88px); overflow: hidden; }\n.section-title { font-size: 10px; font-weight: 700; letter-spacing: .12em;\n                 color: #475569; text-transform: uppercase; margin-bottom: 12px; }\n.card { background: #161b27; border: 1px solid #1e2433; border-radius: 6px;\n        padding: 14px; margin-bottom: 10px; }\n.metric { display: flex; justify-content: space-between; align-items: center;\n          padding: 4px 0; border-bottom: 1px solid #1e2433; }\n.metric:last-child { border-bottom: none; }\n.metric .label { color: #94a3b8; }\n.metric .value { font-weight: 600; color: #f1f5f9; }\n.badge { display: inline-block; padding: 1px 7px; border-radius: 3px; font-size: 11px; font-weight: 600; }\n.badge-green  { background: #14532d; color: #86efac; }\n.badge-yellow { background: #713f12; color: #fde68a; }\n.badge-blue   { background: #1e3a5f; color: #93c5fd; }\n.badge-gray   { background: #1e293b; color: #94a3b8; }\n.kind-pill { background: #1e293b; color: #7dd3fc; padding: 2px 8px;\n             border-radius: 4px; font-size: 11px; margin-right: 4px; }\n/* Overview */\n.overview-wrap { display: flex; width: 100%; height: 100%; }\n.overview-sidebar { width: 280px; flex-shrink: 0; border-right: 1px solid #1e2433;\n                    padding: 20px; overflow-y: auto; }\n.log-pane { flex: 1; padding: 20px; display: flex; flex-direction: column; overflow: hidden; }\n.log-controls { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }\n.log-controls input, .log-controls select {\n  background: #161b27; border: 1px solid #2d3748; color: #e2e8f0;\n  border-radius: 4px; padding: 5px 10px; font-family: inherit; font-size: 12px; outline: none; }\n.log-controls input:focus, .log-controls select:focus { border-color: #3b82f6; }\n.log-btn { background: #1e3a5f; color: #93c5fd; border: 1px solid #2d4a7f; border-radius: 4px;\n           padding: 5px 12px; font-family: inherit; font-size: 12px; cursor: pointer; }\n.log-btn:hover { background: #1e4a7f; }\n#log-table-wrap { flex: 1; overflow-y: auto; }\ntable { width: 100%; border-collapse: collapse; }\nth { position: sticky; top: 0; background: #0f1117; color: #475569;\n     font-size: 10px; letter-spacing: .08em; text-transform: uppercase;\n     padding: 6px 10px; text-align: left; border-bottom: 1px solid #1e2433; }\ntd { padding: 6px 10px; border-bottom: 1px solid #131925; vertical-align: top; }\ntr:hover td { background: #161b27; }\n.event-kind { font-weight: 600; }\n.ek-received { color: #7dd3fc; } .ek-llm_start { color: #a78bfa; }\n.ek-llm_done { color: #86efac; } .ek-sent { color: #6ee7b7; }\n.ek-error { color: #f87171; } .ek-agent_registered { color: #fbbf24; }\n.ek-heartbeat { color: #94a3b8; } .ek-msg_delivered { color: #f9a8d4; }\n.ek-msg_pulled { color: #c4b5fd; } .ek-state_saved { color: #67e8f9; }\n.data-cell { max-width: 260px; overflow: hidden; text-overflow: ellipsis;\n             white-space: nowrap; color: #64748b; cursor: pointer; }\n.data-cell:hover { white-space: normal; word-break: break-all; color: #94a3b8; }\n.ts-cell { white-space: nowrap; color: #475569; font-size: 11px; }\n.empty { color: #475569; text-align: center; padding: 40px; }\n/* Comms */\n.comms-wrap { display: flex; flex-direction: column; width: 100%; height: 100%; }\n#comms-canvas { flex: 1; background: #0c1020; width: 100%; display: block; }\n.msg-feed { height: 210px; border-top: 1px solid #1e2433; padding: 10px 20px; overflow-y: auto; flex-shrink: 0; }\n.msg-row { display: flex; align-items: center; gap: 10px; padding: 3px 0;\n           border-bottom: 1px solid #131925; font-size: 12px; }\n.msg-row:last-child { border-bottom: none; }\n.msg-from { color: #7dd3fc; min-width: 110px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.msg-arrow { color: #3b4a6b; }\n.msg-to { color: #f9a8d4; min-width: 110px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.msg-topic { color: #64748b; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 11px; }\n.msg-ts { color: #334155; font-size: 10px; white-space: nowrap; }\n/* Fleet map */\n#map-container { position: relative; width: 100%; height: 100%; }\n#fleet-map { width: 100%; height: 100%; }\n#map-legend { position: absolute; bottom: 28px; left: 12px; z-index: 1000;\n              background: rgba(15,17,23,0.93); border: 1px solid #1e2433;\n              border-radius: 6px; padding: 12px 16px; font-size: 11px; pointer-events: none; }\n.leg-title { font-size: 10px; font-weight: 700; letter-spacing: .1em; color: #475569;\n             text-transform: uppercase; margin-bottom: 8px; }\n.leg-row { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; color: #94a3b8; }\n.leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }\n.leg-sq  { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }\n#map-stats { position: absolute; top: 12px; right: 12px; z-index: 1000;\n             background: rgba(15,17,23,0.93); border: 1px solid #1e2433;\n             border-radius: 6px; padding: 10px 16px; font-size: 11px; pointer-events: none; min-width: 130px; }\n.stat-row { display: flex; justify-content: space-between; gap: 16px; padding: 2px 0; }\n.stat-lbl { color: #64748b; } .stat-val { color: #f1f5f9; font-weight: 600; }\n#err-banner { display: none; background: #7f1d1d; color: #fca5a5; padding: 8px 24px; font-size: 12px; }\n</style>\n</head>\n<body>\n<div id=\"err-banner\"></div>\n<header>\n  <div class=\"dot\" id=\"status-dot\"></div>\n  <h1>lex-soft platform</h1>\n  <span id=\"ts\">—</span>\n</header>\n<div class=\"tabs\">\n  <button class=\"tab-btn active\" onclick=\"switchTab('overview')\">Overview</button>\n  <button class=\"tab-btn\" onclick=\"switchTab('comms')\">Agent Comms</button>\n  <button class=\"tab-btn\" onclick=\"switchTab('fleet')\">Fleet Map</button>\n</div>\n\n<!-- TAB: Overview -->\n<div class=\"tab-pane\" id=\"tab-overview\" style=\"display:flex\">\n  <div class=\"overview-wrap\">\n    <div class=\"overview-sidebar\">\n      <div class=\"section-title\">Health</div>\n      <div class=\"card\">\n        <div class=\"metric\"><span class=\"label\">total agents</span><span class=\"value\" id=\"total-agents\">—</span></div>\n        <div id=\"by-kind\"></div>\n      </div>\n      <div class=\"section-title\" style=\"margin-top:16px\">Queues</div>\n      <div class=\"card\">\n        <div class=\"metric\"><span class=\"label\">push pending</span><span class=\"value\" id=\"push-pending\">—</span></div>\n        <div class=\"metric\"><span class=\"label\">pull pending</span><span class=\"value\" id=\"pull-pending\">—</span></div>\n      </div>\n    </div>\n    <div class=\"log-pane\">\n      <div class=\"section-title\">Audit log</div>\n      <div class=\"log-controls\">\n        <input id=\"f-agent\" placeholder=\"agent_id filter\" style=\"width:160px\">\n        <select id=\"f-kind\">\n          <option value=\"\">all events</option>\n          <option>received</option><option>llm_start</option><option>llm_done</option>\n          <option>sent</option><option>error</option><option>agent_registered</option>\n          <option>heartbeat</option><option>msg_delivered</option><option>msg_pulled</option>\n          <option>state_saved</option>\n        </select>\n        <input id=\"f-since\" placeholder=\"since (ISO ts)\" style=\"width:180px\">\n        <input id=\"f-limit\" value=\"50\" style=\"width:60px\" type=\"number\" min=\"1\" max=\"500\">\n        <button class=\"log-btn\" onclick=\"fetchAudit()\">refresh</button>\n      </div>\n      <div id=\"log-table-wrap\">\n        <table>\n          <thead><tr><th>time</th><th>agent</th><th>event</th><th>data</th><th>run_id</th></tr></thead>\n          <tbody id=\"log-body\"><tr><td colspan=\"5\" class=\"empty\">loading…</td></tr></tbody>\n        </table>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- TAB: Agent Comms -->\n<div class=\"tab-pane\" id=\"tab-comms\">\n  <div class=\"comms-wrap\">\n    <canvas id=\"comms-canvas\"></canvas>\n    <div class=\"msg-feed\">\n      <div class=\"section-title\" style=\"margin-bottom:6px\">Recent messages</div>\n      <div id=\"msg-feed-body\"></div>\n    </div>\n  </div>\n</div>\n\n<!-- TAB: Fleet Map -->\n<div class=\"tab-pane\" id=\"tab-fleet\">\n  <div id=\"map-container\">\n    <div id=\"fleet-map\"></div>\n    <div id=\"map-legend\">\n      <div class=\"leg-title\">Status</div>\n      <div class=\"leg-row\"><div class=\"leg-dot\" style=\"background:#22c55e\"></div>Driving</div>\n      <div class=\"leg-row\"><div class=\"leg-dot\" style=\"background:#f59e0b\"></div>Charging</div>\n      <div class=\"leg-row\"><div class=\"leg-dot\" style=\"background:#6366f1\"></div>Arrived</div>\n      <div class=\"leg-row\"><div class=\"leg-dot\" style=\"background:#475569\"></div>Idle</div>\n      <div class=\"leg-row\" style=\"margin-top:8px\"><div class=\"leg-sq\" style=\"background:#f87171\"></div>Depot</div>\n      <div class=\"leg-row\"><div style=\"width:10px;height:2px;background:#3b82f6;border-top:1px dashed #3b82f6\"></div>Route</div>\n    </div>\n    <div id=\"map-stats\">\n      <div class=\"leg-title\">Fleet</div>\n      <div class=\"stat-row\"><span class=\"stat-lbl\">total</span><span class=\"stat-val\" id=\"ms-total\">—</span></div>\n      <div class=\"stat-row\"><span class=\"stat-lbl\">driving</span><span class=\"stat-val\" id=\"ms-driving\">—</span></div>\n      <div class=\"stat-row\"><span class=\"stat-lbl\">charging</span><span class=\"stat-val\" id=\"ms-charging\">—</span></div>\n      <div class=\"stat-row\"><span class=\"stat-lbl\">arrived</span><span class=\"stat-val\" id=\"ms-arrived\">—</span></div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"></script>\n<script>\n// ---- Misc ---------------------------------------------------------\nfunction showErr(msg) {\n  var b = document.getElementById('err-banner');\n  b.textContent = msg; b.style.display = 'block';\n  setTimeout(function() { b.style.display = 'none'; }, 4000);\n}\nfunction badge(n, warn) {\n  if (n === 0) return '<span class=\"badge badge-gray\">0</span>';\n  if (warn && n > 0) return '<span class=\"badge badge-yellow\">' + n + '</span>';\n  return '<span class=\"badge badge-blue\">' + n + '</span>';\n}\nfunction esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;'); }\n\n// ---- Tab switching -----------------------------------------------\nfunction switchTab(name) {\n  var btns = document.querySelectorAll('.tab-btn');\n  var names = ['overview','comms','fleet'];\n  btns.forEach(function(b, i) { b.classList.toggle('active', names[i] === name); });\n  document.querySelectorAll('.tab-pane').forEach(function(p) { p.style.display = 'none'; });\n  var pane = document.getElementById('tab-' + name);\n  pane.style.display = (name === 'comms') ? 'flex' : 'block';\n  if (name === 'fleet') { setTimeout(initFleetMap, 50); }\n  if (name === 'comms') { resizeCommsCanvas(); }\n}\n\n// ---- Overview: Health --------------------------------------------\nfunction fetchHealth() {\n  fetch('/v1/health').then(function(r) { return r.json(); }).then(function(d) {\n    if (d.error) { showErr('health: ' + d.error); return; }\n    document.getElementById('total-agents').textContent = d.agents.total;\n    document.getElementById('by-kind').innerHTML = (d.agents.by_kind || []).map(function(e) {\n      return '<div class=\"metric\"><span class=\"kind-pill\">' + esc(e.kind) + '</span><span class=\"value\">' + e.count + '</span></div>';\n    }).join('');\n    document.getElementById('push-pending').innerHTML = badge(d.queues.push_pending, true);\n    document.getElementById('pull-pending').innerHTML = badge(d.queues.pull_pending, true);\n    document.getElementById('ts').textContent = 'updated ' + new Date().toLocaleTimeString();\n    document.getElementById('status-dot').style.cssText = 'width:8px;height:8px;border-radius:50%;background:#22c55e;box-shadow:0 0 6px #22c55e;animation:pulse 2s infinite';\n  }).catch(function(e) {\n    document.getElementById('status-dot').style.cssText = 'width:8px;height:8px;border-radius:50%;background:#ef4444;box-shadow:0 0 6px #ef4444';\n    showErr('health: ' + e.message);\n  });\n}\n\n// ---- Overview: Audit log -----------------------------------------\nfunction fetchAudit() {\n  var params = new URLSearchParams();\n  var agent = document.getElementById('f-agent').value.trim();\n  var kind  = document.getElementById('f-kind').value;\n  var since = document.getElementById('f-since').value.trim();\n  var limit = document.getElementById('f-limit').value;\n  if (agent) params.set('agent_id', agent);\n  if (kind)  params.set('event_kind', kind);\n  if (since) params.set('since', since);\n  if (limit) params.set('limit', limit);\n  fetch('/v1/audit?' + params.toString()).then(function(r) { return r.json(); }).then(function(rows) {\n    if (!Array.isArray(rows)) { showErr('audit: ' + JSON.stringify(rows)); return; }\n    var tbody = document.getElementById('log-body');\n    if (!rows.length) { tbody.innerHTML = '<tr><td colspan=\"5\" class=\"empty\">no events</td></tr>'; return; }\n    tbody.innerHTML = rows.map(function(r) {\n      var ts  = r.ts ? r.ts.replace('T',' ').replace('Z','') : '';\n      var run = r.run_id ? r.run_id.slice(0,12) + '…' : '';\n      var ek  = r.event_kind || '';\n      return '<tr>'\n        + '<td class=\"ts-cell\">' + ts + '</td>'\n        + '<td>' + esc(r.agent_id||'') + '</td>'\n        + '<td><span class=\"event-kind ek-' + ek + '\">' + ek + '</span></td>'\n        + '<td class=\"data-cell\" title=\"' + esc(r.data||'') + '\">' + esc(r.data||'') + '</td>'\n        + '<td class=\"ts-cell\">' + run + '</td>'\n        + '</tr>';\n    }).join('');\n  }).catch(function(e) { showErr('audit: ' + e.message); });\n}\n\n// ---- Comms: force-directed graph ---------------------------------\nvar CS = { nodes: {}, edges: {}, msgs: [], raf: null };\n\nfunction fetchCommsData() {\n  fetch('/v1/audit?event_kind=msg_delivered&limit=200')\n    .then(function(r) { return r.json(); })\n    .then(function(rows) {\n      if (!Array.isArray(rows)) return;\n      var ec = {}, ns = {};\n      var msgs = [];\n      rows.forEach(function(r) {\n        var from = '', to = r.agent_id || '', topic = '';\n        try { var d = JSON.parse(r.data || '{}'); from = d.from || ''; topic = d.topic || ''; } catch(e) {}\n        if (!from && !to) return;\n        if (from) ns[from] = true;\n        if (to)   ns[to]   = true;\n        var key = from + '|' + to;\n        ec[key] = (ec[key] || 0) + 1;\n        msgs.push({ from: from, to: to, topic: topic, ts: r.ts });\n      });\n      var W = commsCanvas ? commsCanvas.width : 800;\n      var H = commsCanvas ? commsCanvas.height : 400;\n      Object.keys(ns).forEach(function(id) {\n        if (!CS.nodes[id]) {\n          CS.nodes[id] = {\n            id: id,\n            x: W/2 + (Math.random()-0.5)*200,\n            y: H/2 + (Math.random()-0.5)*200,\n            vx: 0, vy: 0\n          };\n        }\n      });\n      CS.edges = ec;\n      CS.msgs  = msgs;\n      renderMsgFeed(msgs);\n    }).catch(function() {});\n}\n\nfunction renderMsgFeed(msgs) {\n  var el = document.getElementById('msg-feed-body');\n  if (!msgs.length) {\n    el.innerHTML = '<div style=\"color:#475569;padding:6px 0;font-size:12px\">no agent messages yet</div>';\n    return;\n  }\n  el.innerHTML = msgs.slice(0,25).map(function(m) {\n    var ts = m.ts ? m.ts.replace('T',' ').replace('Z','').slice(0,19) : '';\n    return '<div class=\"msg-row\">'\n      + '<span class=\"msg-from\">' + esc(m.from||'—') + '</span>'\n      + '<span class=\"msg-arrow\">&#8594;</span>'\n      + '<span class=\"msg-to\">' + esc(m.to||'—') + '</span>'\n      + '<span class=\"msg-topic\">' + esc(m.topic||'') + '</span>'\n      + '<span class=\"msg-ts\">' + ts + '</span>'\n      + '</div>';\n  }).join('');\n}\n\nvar commsCanvas, commsCtx;\nfunction initCommsCanvas() {\n  commsCanvas = document.getElementById('comms-canvas');\n  commsCtx = commsCanvas.getContext('2d');\n  resizeCommsCanvas();\n  window.addEventListener('resize', function() {\n    if (document.getElementById('tab-comms').style.display !== 'none') resizeCommsCanvas();\n  });\n  animateComms();\n}\n\nfunction resizeCommsCanvas() {\n  if (!commsCanvas) return;\n  var wrap = commsCanvas.parentElement;\n  commsCanvas.width  = wrap.clientWidth  || 800;\n  commsCanvas.height = Math.max(100, (wrap.clientHeight || 500) - 210);\n}\n\nvar KIND_COLORS = {\n  'truck': '#22c55e', 'depot': '#f59e0b', 'tms': '#3b82f6',\n  'charge': '#a78bfa', 'logistics': '#f87171', 'platform': '#67e8f9', 'oms': '#fbbf24'\n};\nfunction nodeColor(id) {\n  var lower = id.toLowerCase();\n  var keys = Object.keys(KIND_COLORS);\n  for (var i = 0; i < keys.length; i++) {\n    if (lower.indexOf(keys[i]) >= 0) return KIND_COLORS[keys[i]];\n  }\n  return '#7dd3fc';\n}\n\nfunction animateComms() {\n  if (!commsCanvas || !commsCtx) { CS.raf = requestAnimationFrame(animateComms); return; }\n  var ctx = commsCtx;\n  var W = commsCanvas.width, H = commsCanvas.height;\n  ctx.clearRect(0, 0, W, H);\n\n  var nodes = Object.values(CS.nodes);\n  var K_rep = 6000, K_spring = 0.035, K_damp = 0.82, K_center = 0.006;\n\n  nodes.forEach(function(n) {\n    n.vx += (W/2 - n.x) * K_center;\n    n.vy += (H/2 - n.y) * K_center;\n    nodes.forEach(function(m) {\n      if (m === n) return;\n      var dx = n.x - m.x, dy = n.y - m.y;\n      var d2 = dx*dx + dy*dy + 1, d = Math.sqrt(d2);\n      var f = K_rep / d2;\n      n.vx += f * dx / d; n.vy += f * dy / d;\n    });\n  });\n\n  Object.keys(CS.edges).forEach(function(key) {\n    var parts = key.split('|');\n    var a = CS.nodes[parts[0]], b = CS.nodes[parts[1]];\n    if (!a || !b) return;\n    var dx = b.x - a.x, dy = b.y - a.y;\n    var d = Math.sqrt(dx*dx + dy*dy) + 0.01;\n    var target = 150, f = (d - target) * K_spring;\n    a.vx += f*dx/d; a.vy += f*dy/d;\n    b.vx -= f*dx/d; b.vy -= f*dy/d;\n  });\n\n  nodes.forEach(function(n) {\n    n.vx *= K_damp; n.vy *= K_damp;\n    n.x = Math.max(50, Math.min(W-50, n.x + n.vx));\n    n.y = Math.max(50, Math.min(H-50, n.y + n.vy));\n  });\n\n  // Draw edges\n  Object.entries(CS.edges).forEach(function(kv) {\n    var parts = kv[0].split('|'), cnt = kv[1];\n    var a = CS.nodes[parts[0]], b = CS.nodes[parts[1]];\n    if (!a || !b) return;\n    var lw = Math.min(1 + Math.log(cnt+1) * 1.4, 7);\n    var mx = (a.x+b.x)/2 - (b.y-a.y)*0.18;\n    var my = (a.y+b.y)/2 + (b.x-a.x)*0.18;\n    ctx.beginPath();\n    ctx.moveTo(a.x, a.y);\n    ctx.quadraticCurveTo(mx, my, b.x, b.y);\n    ctx.strokeStyle = 'rgba(99,102,241,0.45)';\n    ctx.lineWidth = lw;\n    ctx.stroke();\n    // Arrowhead\n    var angle = Math.atan2(b.y - my, b.x - mx);\n    ctx.beginPath();\n    ctx.moveTo(b.x - 9*Math.cos(angle-0.4), b.y - 9*Math.sin(angle-0.4));\n    ctx.lineTo(b.x, b.y);\n    ctx.lineTo(b.x - 9*Math.cos(angle+0.4), b.y - 9*Math.sin(angle+0.4));\n    ctx.strokeStyle = '#818cf8';\n    ctx.lineWidth = 1.5;\n    ctx.stroke();\n    // Count\n    ctx.fillStyle = '#334155';\n    ctx.font = '10px monospace';\n    ctx.textAlign = 'center';\n    ctx.fillText(cnt, (a.x+b.x)/2, (a.y+b.y)/2 - 6);\n  });\n\n  // Draw nodes\n  nodes.forEach(function(n) {\n    var r = 20, c = nodeColor(n.id);\n    // Glow\n    ctx.beginPath();\n    ctx.arc(n.x, n.y, r+4, 0, Math.PI*2);\n    ctx.fillStyle = c.replace(')', ',0.08)').replace('rgb','rgba').replace('#','rgba(').replace(/rgba\\((..)(..)(..),/,\n      function(m,r,g,b){ return 'rgba('+parseInt(r,16)+','+parseInt(g,16)+','+parseInt(b,16)+','; });\n    // Simple outer ring\n    ctx.beginPath();\n    ctx.arc(n.x, n.y, r+3, 0, Math.PI*2);\n    ctx.strokeStyle = c + '33';\n    ctx.lineWidth = 3;\n    ctx.stroke();\n    // Node circle\n    ctx.beginPath();\n    ctx.arc(n.x, n.y, r, 0, Math.PI*2);\n    ctx.fillStyle = '#161b27';\n    ctx.fill();\n    ctx.strokeStyle = c;\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    // Label\n    var label = n.id.length > 14 ? n.id.slice(0,13)+'…' : n.id;\n    ctx.fillStyle = c;\n    ctx.font = '9px monospace';\n    ctx.textAlign = 'center';\n    ctx.fillText(label, n.x, n.y + r + 13);\n    ctx.textAlign = 'left';\n  });\n\n  if (nodes.length === 0) {\n    ctx.fillStyle = '#2d3748';\n    ctx.font = '13px monospace';\n    ctx.textAlign = 'center';\n    ctx.fillText('no agent communications recorded yet', W/2, H/2);\n    ctx.textAlign = 'left';\n  }\n\n  CS.raf = requestAnimationFrame(animateComms);\n}\n\n// ---- Fleet Map (Leaflet) -----------------------------------------\nvar fleetMap = null;\nvar truckMarkers = {};\nvar depotMarkers = {};\n\nvar STATUS_COLORS = { driving: '#22c55e', charging: '#f59e0b', arrived: '#6366f1', idle: '#475569' };\n\nfunction strHash(s) {\n  var h = 5381;\n  for (var i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) & 0x7fffffff;\n  return h;\n}\n\nfunction agentPos(id, kind) {\n  var h = strHash(id);\n  if (kind === 'depot') {\n    var locs = [[53.55,9.99],[52.52,13.41],[48.14,11.58],[50.93,6.95],[50.11,8.68],[48.78,9.18]];\n    return locs[h % locs.length];\n  }\n  var lat = 47.5 + ((h >> 3) % 7500) / 1000;\n  var lon = 6.0  + (((h * 7) >> 2) % 9000) / 1000;\n  return [lat, lon];\n}\n\nfunction topicToStatus(topic) {\n  if (!topic) return 'idle';\n  if (topic.indexOf('charge') >= 0) return 'charging';\n  if (topic.indexOf('dispatch') >= 0 || topic.indexOf('assign') >= 0) return 'driving';\n  if (topic.indexOf('arrived') >= 0 || topic.indexOf('capacity') >= 0) return 'arrived';\n  return 'idle';\n}\n\nfunction makeTruckIcon(status, id) {\n  var c = STATUS_COLORS[status] || '#475569';\n  var svg = '<svg width=\"34\" height=\"34\" viewBox=\"0 0 34 34\" xmlns=\"http://www.w3.org/2000/svg\">'\n    + '<circle cx=\"17\" cy=\"17\" r=\"15\" fill=\"#161b27\" stroke=\"' + c + '\" stroke-width=\"2.5\"/>'\n    + '<text x=\"17\" y=\"22\" text-anchor=\"middle\" font-size=\"14\" font-family=\"monospace\" fill=\"' + c + '\">🚛</text>'\n    + '</svg>';\n  var label = id.length > 8 ? id.slice(-6) : id;\n  return L.divIcon({\n    html: '<div style=\"position:relative\">' + svg\n      + '<div style=\"position:absolute;top:36px;left:50%;transform:translateX(-50%);white-space:nowrap;'\n      + 'background:rgba(15,17,23,0.85);color:' + c + ';font-family:monospace;font-size:9px;'\n      + 'padding:1px 4px;border-radius:2px;border:1px solid ' + c + '\">' + label + '</div></div>',\n    className: '',\n    iconSize: [34, 50],\n    iconAnchor: [17, 17],\n    popupAnchor: [0, -20]\n  });\n}\n\nfunction makeDepotIcon() {\n  var svg = '<svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" xmlns=\"http://www.w3.org/2000/svg\">'\n    + '<rect x=\"2\" y=\"2\" width=\"18\" height=\"18\" rx=\"3\" fill=\"#1e293b\" stroke=\"#f87171\" stroke-width=\"2\"/>'\n    + '<text x=\"11\" y=\"15\" text-anchor=\"middle\" font-size=\"11\" font-family=\"monospace\" fill=\"#f87171\" font-weight=\"bold\">D</text>'\n    + '</svg>';\n  return L.divIcon({ html: svg, className: '', iconSize: [22,22], iconAnchor: [11,11], popupAnchor: [0,-12] });\n}\n\nfunction initFleetMap() {\n  if (fleetMap) { fleetMap.invalidateSize(); return; }\n  fleetMap = L.map('fleet-map').setView([51.5, 10.0], 5);\n  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\n    attribution: '© <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a>',\n    maxZoom: 18\n  }).addTo(fleetMap);\n  fetchFleetPositions();\n  setInterval(fetchFleetPositions, 10000);\n}\n\nfunction fetchFleetPositions() {\n  if (!fleetMap) return;\n  Promise.all([\n    fetch('/v1/agents').then(function(r) { return r.json(); }).catch(function() { return []; }),\n    fetch('/v1/audit?event_kind=msg_delivered&limit=200').then(function(r) { return r.json(); }).catch(function() { return []; })\n  ]).then(function(results) {\n    var agents = Array.isArray(results[0]) ? results[0] : [];\n    var msgs   = Array.isArray(results[1]) ? results[1] : [];\n    var agentTopic = {};\n    msgs.forEach(function(m) {\n      try {\n        var d = JSON.parse(m.data || '{}');\n        var from = d.from || '';\n        if (from && !agentTopic[from]) agentTopic[from] = d.topic || '';\n        if (m.agent_id && !agentTopic[m.agent_id]) agentTopic[m.agent_id] = d.topic || '';\n      } catch(e) {}\n    });\n    var trucks = agents.filter(function(a) { return a.kind === 'truck'; });\n    var depots = agents.filter(function(a) { return a.kind === 'depot'; });\n    document.getElementById('ms-total').textContent = trucks.length;\n    var driving = 0, charging = 0, arrived = 0;\n    trucks.forEach(function(a) {\n      var pos = agentPos(a.id, 'truck');\n      var topic = agentTopic[a.id] || '';\n      var status = topicToStatus(topic);\n      if (status === 'driving') driving++;\n      else if (status === 'charging') charging++;\n      else arrived++;\n      var html = '<b>' + esc(a.id) + '</b><br>Status: ' + status + '<br>Last topic: ' + esc(topic || 'none');\n      if (truckMarkers[a.id]) {\n        truckMarkers[a.id].setIcon(makeTruckIcon(status, a.id));\n        truckMarkers[a.id].getPopup().setContent(html);\n      } else {\n        truckMarkers[a.id] = L.marker(pos, { icon: makeTruckIcon(status, a.id) })\n          .bindPopup(html).addTo(fleetMap);\n      }\n    });\n    depots.forEach(function(a) {\n      if (!depotMarkers[a.id]) {\n        var pos = agentPos(a.id, 'depot');\n        depotMarkers[a.id] = L.marker(pos, { icon: makeDepotIcon() })\n          .bindPopup('<b>' + esc(a.name || a.id) + '</b>').addTo(fleetMap);\n      }\n    });\n    document.getElementById('ms-driving').textContent  = driving;\n    document.getElementById('ms-charging').textContent = charging;\n    document.getElementById('ms-arrived').textContent  = arrived;\n  });\n}\n\n// ---- Bootstrap ----------------------------------------------------\nfetchHealth();\nfetchAudit();\nsetInterval(fetchHealth, 5000);\nsetInterval(fetchAudit, 10000);\ninitCommsCanvas();\nfetchCommsData();\nsetInterval(fetchCommsData, 10000);\n</script>\n</body>\n</html>\n"
}

